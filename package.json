{
  "name": "pencil-sync",
  "version": "0.5.1",
  "description": "Bidirectional sync between .pen design files and frontend code via Claude CLI",
  "license": "Apache-2.0",
  "author": "pencil-sync contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/celstnblacc/pencil-sync.git"
  },
  "keywords": [
    "pencil",
    "design-to-code",
    "claude",
    "sync",
    "pen-files",
    "bidirectional",
    "AI",
    "frontend"
  ],
  "files": [
    "dist/",
    "!dist/__tests__/",
    "prompts/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "pencil-sync": "./dist/index.js",
    "pencil-sync-mcp": "./dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "watch": "node dist/index.js watch",
    "sync": "node dist/index.js sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ink": "^7.1.0",
    "ora": "^8.1.1",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.0.18"
  }
}
